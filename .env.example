# Chatbot AI escalation (optional).
# Leave unset to run the chatbot in rule-based + WhatsApp-handoff mode.
# When set, /api/chat will call the LLM for complex questions.
# Example: OPENAI_API_KEY=sk-...
OPENAI_API_KEY=

